#!/bin/sh
# TeamWERK Harness — pre-push (vollständiges Gate, spiegelt was sonst CI wäre).
# Blockiert den Push, wenn Build/Tests/Lint fehlschlagen.
#
# Installation: `make hooks` (setzt core.hooksPath auf .githooks).
# Notausgang (bewusst, mit Vorsicht):  git push --no-verify

set -e

GO="$( [ -x /usr/local/go/bin/go ] && echo /usr/local/go/bin/go || echo go )"
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# GOROOT + PATH explizit auf den aktiven Toolchain (1.26.x) setzen, damit
# golangci-lint nicht /usr/local/go (1.25-Bootstrap) als Stdlib-Pfad und
# Go-Binary verwendet (Mismatch "go1.25 does not match go tool version go1.26").
export GOROOT="$("$GO" env GOROOT)"
export PATH="$GOROOT/bin:$PATH"

echo "▸ pre-push: go vet ./..."
"$GO" vet ./...

echo "▸ pre-push: go test ./...  (inkl. Architektur-Test; Race-Detector via 'make test-race')"
"$GO" test ./...

if command -v golangci-lint >/dev/null 2>&1; then
	echo "▸ pre-push: golangci-lint run ./..."
	golangci-lint run ./...
else
	echo "⚠ pre-push: golangci-lint nicht gefunden — übersprungen."
fi

echo "▸ pre-push: Frontend build (tsc + vite)"
pnpm -C web build

if ! command -v xmllint >/dev/null 2>&1; then
	echo "⚠ pre-push: xmllint (libxml2) nicht gefunden — SEPA-XSD-Gate wird bei den"
	echo "  Frontend-Tests lokal übersprungen. Installation: 'brew install libxml2'"
	echo "  (macOS) bzw. 'apt-get install libxml2-utils' (Debian). Das CI-Gate"
	echo "  prüft es verpflichtend — Push wird nicht blockiert."
fi

echo "▸ pre-push: Frontend tests (vitest)"
pnpm -C web test

echo "▸ pre-push: Frontend lint (eslint)"
pnpm -C web lint

if command -v openspec >/dev/null 2>&1; then
	echo "▸ pre-push: openspec validate --all"
	openspec validate --all || true
else
	echo "⚠ pre-push: openspec nicht gefunden — übersprungen."
fi

echo "✓ pre-push: alle Gates grün."
exit 0
