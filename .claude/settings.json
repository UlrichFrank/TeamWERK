      "Bash(go vet *)",
      "Bash(go build *)",
      "Bash(go run *)",
      "Bash(go env *)",
      "Bash(go doc *)",
      "Bash(gofmt *)",
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make coverage)",
      "Bash(make build)",
      "Bash(make hooks)",
      "Bash(make init)",
      "Bash(make env)",
      "Bash(pnpm -C web build)",
      "Bash(pnpm -C web test)",
      "Bash(pnpm -C web lint)",
      "Bash(pnpm install *)",
      "Bash(openspec list *)",
      "Bash(openspec show *)",
      "Bash(openspec status *)",
