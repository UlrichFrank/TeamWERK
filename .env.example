# Server
PORT=8080
DB_PATH=./teamwerk.db
JWT_SECRET=change-me-to-a-random-secret
BASE_URL=https://intern.team-stuttgart.org
UPLOAD_DIR=/var/lib/teamwerk/storage/uploads
# Verzeichnis für die append-only SEPA-Beitragslauf-Protokolle (ins Backup aufnehmen!)
BEITRAGSLAUF_DIR=/var/lib/teamwerk/storage/beitragslauf-protokolle

# SMTP (agenturserver.de Mailaccount)
SMTP_HOST=mail.agenturserver.de
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TeamWERK <teamwerk@team-stuttgart.org>"
# Auf true setzen um E-Mail-Versand lokal zu deaktivieren
MAILER_DISABLED=

# Web Push (VAPID) — generate with: go run ./cmd/teamwerk gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:vorstand@team-stuttgart.org

# Zero-Knowledge (Modell B): Bank-/SEPA-PII wird ausschließlich CLIENTseitig ver-/
# entschlüsselt. Der Server hält KEINEN Entschlüsselungsschlüssel — kein FIELD_ENCRYPTION_KEY
# mehr nötig. (Der frühere serverseitige At-Rest-Schlüssel wurde nach der Bestandsmigration
# entfernt; siehe docs/agent/10-deployment.md.)

# Monitoring (siehe docs/monitoring.md)
# Schützt GET /api/metrics (Prometheus-Textformat). Leer lassen → Endpoint
# deaktiviert (404). Setzen → externer Scraper sendet "Authorization: Bearer <token>".
METRICS_TOKEN=
# Log-Ausgabeformat: json (Default, maschinenlesbar nach stdout) oder text (lokale DX).
LOG_FORMAT=json

# Spielvideos (self-hosted HLS)
# HMAC-Secret für kurzlebige Stream-Token (getrennt von JWT_SECRET, damit ein
# Token-Leak die JWTs nicht betrifft). Leer → Stream-Token-Signierung deaktiviert.
VIDEO_STREAM_SECRET=
# Wurzelverzeichnis der Videos (raw/, processed/, uploads/).
VIDEO_STORAGE_DIR=/storage/videos
# Disk-Puffer in Bytes, der beim Pre-Upload-Check freigehalten wird (Default 1 GiB).
VIDEO_RESERVED_BYTES=1073741824

# Spielbericht → TYPO3 Publisher (spielbericht-typo3-publisher).
# TYPO3-Extension-Endpoint auf www.team-stuttgart.org (siehe Nachbar-Repo
# ../team-stuttgart-org, feat(match-report-import)). Leere Werte deaktivieren
# den Publisher (Handler liefert ErrPublisherNotConfigured, kein Crash).
# Der TYPO3_IMPORT_TOKEN MUSS auf der TYPO3-Seite in additional.php identisch
# gesetzt sein — sonst 401. In Prod: langen Zufallswert verwenden.
TYPO3_IMPORT_URL=
TYPO3_IMPORT_TOKEN=
# Season-Ordner /spielberichte/{YYYY-YYYY}/ legt die TYPO3-Extension seit
# AC-8 (Contract-Version mit `season`-Feld) selbst an — kein zusätzlicher
# Config-Eintrag mehr nötig.
# Verzeichnis für Draft-Bilder der Spielberichte (pro Bericht ein Unterordner,
# nach state='published' automatisch aufgeräumt).
MATCH_REPORT_IMAGE_DIR=./storage/match-report-images

# Deployment (used by make deploy)
REMOTE=user@host-or-ssh-alias
REMOTE_DIR=/usr/local/bin

# Server-Umzug (nur während einer Migration setzen; sonst leer lassen)
# Siehe deploy/server-migration-runbook.md und die Makefile-Targets
# server-bootstrap / server-sync-data / server-cutover.
# REMOTE_NEW=user@neuer-host-oder-ssh-alias
# REMOTE_NEW_DIR=/usr/local/bin
# BASE_URL_NEW=https://neue-domain.example.org

# Matomo Client-Side Tracking (anonym, cookieless).
# Beide Variablen müssen für aktives Tracking gesetzt sein.
# Werden beim Vite-Build in die Frontend-Bundle eingebacken — kein Secret.
# Leer lassen → Tracking deaktiviert (Default für lokale Entwicklung).
VITE_MATOMO_URL=
VITE_MATOMO_SITE_ID=
