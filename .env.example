# Server
PORT=8080
DB_PATH=./teamwerk.db
JWT_SECRET=change-me-to-a-random-secret
BASE_URL=https://intern.team-stuttgart.org
UPLOAD_DIR=/var/lib/teamwerk/storage/uploads
# Verzeichnis für die append-only SEPA-Beitragslauf-Protokolle (ins Backup aufnehmen!)
BEITRAGSLAUF_DIR=/var/lib/teamwerk/storage/beitragslauf-protokolle

# SMTP (agenturserver.de Mailaccount)
SMTP_HOST=mail.agenturserver.de
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TeamWERK <teamwerk@team-stuttgart.org>"
# Auf true setzen um E-Mail-Versand lokal zu deaktivieren
MAILER_DISABLED=

# Web Push (VAPID) — generate with: go run ./cmd/teamwerk gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:vorstand@team-stuttgart.org

# At-Rest-Verschlüsselung der Bank-/SEPA-PII (AES-256-GCM) — generate with:
#   go run ./cmd/teamwerk gen-encryption-key
# PFLICHT: ohne gültigen 32-Byte-base64-Schlüssel startet der Server nicht.
# SEPARAT vom DB-Backup sichern (Passwort-Manager). Schlüsselverlust = Datenverlust!
FIELD_ENCRYPTION_KEY=

# Monitoring (siehe docs/monitoring.md)
# Schützt GET /api/metrics (Prometheus-Textformat). Leer lassen → Endpoint
# deaktiviert (404). Setzen → externer Scraper sendet "Authorization: Bearer <token>".
METRICS_TOKEN=
# Log-Ausgabeformat: json (Default, maschinenlesbar nach stdout) oder text (lokale DX).
LOG_FORMAT=json

# Deployment (used by make deploy)
REMOTE=user@host-or-ssh-alias
REMOTE_DIR=/usr/local/bin

# Matomo Client-Side Tracking (anonym, cookieless).
# Beide Variablen müssen für aktives Tracking gesetzt sein.
# Werden beim Vite-Build in die Frontend-Bundle eingebacken — kein Secret.
# Leer lassen → Tracking deaktiviert (Default für lokale Entwicklung).
VITE_MATOMO_URL=
VITE_MATOMO_SITE_ID=
