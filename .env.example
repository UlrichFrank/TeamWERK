# Server
PORT=8080
DB_PATH=./teamwerk.db
JWT_SECRET=change-me-to-a-random-secret
BASE_URL=https://intern.team-stuttgart.org
UPLOAD_DIR=/var/lib/teamwerk/storage/uploads

# SMTP (agenturserver.de Mailaccount)
SMTP_HOST=mail.agenturserver.de
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TeamWERK <teamwerk@team-stuttgart.org>"
# Auf true setzen um E-Mail-Versand lokal zu deaktivieren
MAILER_DISABLED=

# Web Push (VAPID) — generate with: go run ./cmd/teamwerk gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:vorstand@team-stuttgart.org

# Deployment (used by make deploy)
REMOTE=user@host-or-ssh-alias
REMOTE_DIR=/usr/local/bin
