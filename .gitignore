# Binaries
bin/
# Root-Binary aus `go build ./cmd/teamwerk`. Root-geankert (/teamwerk), sonst
# würde das ungeankerte Pattern auch das Verzeichnis cmd/teamwerk/ ignorieren
# und neue Dateien dort (z.B. Tests) bräuchten `git add -f`.
/teamwerk

# Embedded frontend build
cmd/teamwerk/web/dist/

# SQLite
*.db

# Lokale Backups und Uploads
teamwerk-backup.db
backup/
storage/
*.db-shm
*.db-wal

# Environment
.env
web/.env
web/.env.local
web/.env.production
web/.env.development
# (web/.env.example bleibt getrackt als Dokumentation)

# Frontend
web/dist/
web/node_modules/
web/tsconfig.tsbuildinfo

# Go test artifacts
*.test
coverage.out

# Vitest coverage output (vom Metrics-Tool aufgerufen)
web/coverage/

# air (auto-reload tool)
tmp/
build-errors.log

# macOS
.DS_Store

# Claude Code
.claude/settings.local.json

# Deploy tracking
.deployed-hash
web/public/changes.json

# Code-Metrics: generierter Report (thresholds.yml und .gitkeep bleiben getrackt)
metrics/REPORT.md

# Mitglieder-CSV-Exporte im Repo-Root (PII) — testdata/*.csv bleiben getrackt
/*.csv

# Affinity-Designer-Arbeitsdateien im Repo-Root (Icon-/Asset-Exporte)
/*.af
/*.af~lock~
